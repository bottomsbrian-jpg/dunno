# NEXUS Environment Variables
# Copy this file to .env and fill in your keys
# DO NOT commit .env to GitHub

NEXUS_TRADING_MODE=paper
NEXUS_LIVE_CONFIRMED=false
NEXUS_CYCLE_INTERVAL_SECONDS=3600

# Binance API (for crypto trading)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here

# Alpaca API (for stocks - optional)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET=your_alpaca_secret_here
